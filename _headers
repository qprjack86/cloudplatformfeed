/*
  Content-Security-Policy: default-src 'self'; base-uri 'none'; object-src 'none'; form-action 'none'; frame-ancestors 'none'; script-src 'self'; connect-src 'self'; img-src 'self' data: https://*.ytimg.com; style-src 'self'; manifest-src 'self'; worker-src 'self'; media-src 'self'; upgrade-insecure-requests
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# The service worker file must never be HTTP-cached. If the CDN serves a stale
# sw.js the browser cannot detect a new service worker version, so users get the
# old site until a hard-refresh. no-store bypasses both the CDN and browser cache.
/sw.js
  Cache-Control: no-store

# The HTML entry-point should also revalidate on every request so a new deploy
# is visible on a normal (soft) refresh.
/index.html
  Cache-Control: no-cache

/
  Cache-Control: no-cache