{
  "name": "security-response-headers",
  "properties": {
    "actions": [
      {
        "name": "ModifyResponseHeader",
        "parameters": {
          "typeName": "DeliveryRuleHeaderActionParameters",
          "headerAction": "Overwrite",
          "headerName": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'none'; object-src 'none'; form-action 'none'; frame-ancestors 'none'; script-src 'self'; connect-src 'self'; img-src 'self' data: https://*.ytimg.com; style-src 'self'; manifest-src 'self'; worker-src 'self'; media-src 'self'; upgrade-insecure-requests"
        }
      },
      {
        "name": "ModifyResponseHeader",
        "parameters": {
          "typeName": "DeliveryRuleHeaderActionParameters",
          "headerAction": "Overwrite",
          "headerName": "X-Frame-Options",
          "value": "DENY"
        }
      },
      {
        "name": "ModifyResponseHeader",
        "parameters": {
          "typeName": "DeliveryRuleHeaderActionParameters",
          "headerAction": "Overwrite",
          "headerName": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      }
    ],
    "conditions": [
      {
        "name": "RequestScheme",
        "parameters": {
          "operator": "Equal",
          "negateCondition": false,
          "matchValues": [
            "HTTPS"
          ],
          "typeName": "DeliveryRuleRequestSchemeConditionParameters"
        }
      }
    ]
  }
}
