{
  "canonicalHost": "cpfeed.cloud",
  "canonicalUrl": "https://cpfeed.cloud",
  "validation": {
    "requiredArticleFields": [
      "title",
      "link",
      "published",
      "summary",
      "blog",
      "blogId",
      "author"
    ],
    "optionalArticleFieldsWithDefaults": {
      "lifecycleState": "ga",
      "datePrecision": "day"
    },
    "minArticleCoveragePercent": 85
  },
  "deduplication": {
    "keepRetirementDatesEvenIfDuplicate": true,
    "titleNormalizationThreshold": 85,
    "urlNormalizationStrict": true
  },
  "microsoftLifecycle": {
    "enabled": true,
    "products": [
      "windows-server",
      "mssqlserver",
      "msexchange",
      "sharepoint",
      "dotnet",
      "dotnetfx",
      "powershell",
      "visual-studio"
    ],
    "milestones": [
      "eoas",
      "eol"
    ],
    "maxEvents": 120
  },
  "categoryMappings": {
    "azure": {
      "Compute": [
        "azurecompute",
        "container",
        "virtual machine",
        "aks",
        "aspire"
      ],
      "Data & AI": [
        "azure-databricks",
        "data",
        "machine learning",
        "cognitive",
        "analytics"
      ],
      "Infrastructure": [
        "azureinfrastructureblog",
        "network",
        "storage",
        "database"
      ],
      "Security": [
        "microsoftsentinelblog",
        "defender",
        "security",
        "compliance",
        "sentinel"
      ],
      "Management & Governance": [
        "azuregovernanceandmanagementblog",
        "monitor",
        "policy",
        "management"
      ],
      "Integration": [
        "integrationsonazureblog",
        "messaging",
        "integration"
      ],
      "Identity & Access": [
        "identity",
        "entra",
        "active directory"
      ],
      "Migration": [
        "azuremigrationblog",
        "migrate"
      ],
      "Azure Stack": [
        "azurestackblog"
      ],
      "Other": []
    },
    "m365": {
      "Collaboration": [
        "Teams",
        "SharePoint",
        "Outlook",
        "Exchange",
        "OneDrive",
        "Yammer",
        "Skype"
      ],
      "Productivity": [
        "Word",
